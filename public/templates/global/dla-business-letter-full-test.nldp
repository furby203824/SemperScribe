      "line1": "8725 JOHN J. KINGMAN ROAD",
      "line2": "FORT BELVOIR, VIRGINIA 22060-6221",
      "line3": ""
    },
    "paragraphs": [
      {
        "id": 1,
        "level": 1,
        "content": "This letter is to inform you that the Defense Logistics Agency has completed its annual review of Contract SPRXXXXX-XX-D-XXXX. This comprehensive test template exercises all available fields in the DLA business letter format.",
        "isMandatory": true
      },
      {
        "id": 2,
        "level": 1,
        "content": "Based on our review, the following areas were evaluated and scored in accordance with the established performance criteria. The overall performance rating for the contract period was satisfactory."
      },
      {
        "id": 3,
        "level": 2,
        "content": "Delivery schedule adherence was rated as exceeds expectations, with 98% of deliveries meeting or beating the required delivery date."
      },
      {
        "id": 4,
        "level": 2,
        "content": "Quality assurance metrics met all contractual requirements. The defect rate remained below the 2% threshold throughout the evaluation period."
      },
      {
        "id": 5,
        "level": 1,
        "content": "We look forward to continuing our partnership and request your written acknowledgment of this performance evaluation within 30 days of receipt. Should you have any questions, please contact our Contracting Officer, Mr. David Chen, at (703) 767-1234 or david.chen@dla.mil."
      }
    ],
    "vias": [],
    "references": [
      "Contract SPRXXXXX-XX-D-XXXX, awarded January 15, 2024",
      "DLA Acquisition Directive 5025.01, \"Performance Evaluation Procedures,\" March 1, 2023"
    ],
    "enclosures": [
      "Performance Evaluation Summary Report",
      "Delivery Schedule Compliance Data",
      "Quality Assurance Metrics Dashboard"
    ],
