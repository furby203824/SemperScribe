      "recipientName": "Ms. Jane A. Rodriguez",
      "recipientTitle": "Senior Vice President, Government Programs",
      "businessName": "National Defense Systems Inc.",
      "recipientAddress": "4500 Industrial Boulevard\nSuite 200\nArlington, VA 22203",
      "salutation": "Dear Ms. Rodriguez:",
      "subj": "CONTRACT RENEWAL AND PERFORMANCE REVIEW",
      "complimentaryClose": "Sincerely,",
      "signerFullName": "ROBERT T. WILLIAMS",
      "delegationText": "",
